CURS3D_PUBLIC_ADDR=/dns4/node.example.com/tcp/4337
CURS3D_API_ALLOW_ORIGIN=https://explorer.example.com
CURS3D_API_TOKEN=replace-with-long-random-token
CURS3D_RPC_TOKEN=replace-with-long-random-token
CURS3D_FAUCET_WALLET=/run/curs3d/faucet.json
CURS3D_FAUCET_PASSWORD_FILE=/run/curs3d/faucet.password
CURS3D_FAUCET_FEE=1000
CURS3D_FAUCET_COOLDOWN_FILE=/var/lib/curs3d/faucet_cooldowns.json
