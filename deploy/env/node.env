# CURS3D Node Environment Configuration
# Copy this file and fill in the values before deployment

# Public multiaddress for P2P bootstrapping
# Example: /dns4/node.curs3d.io/tcp/4337
CURS3D_PUBLIC_ADDR=/dns4/node.example.com/tcp/4337

# CORS: which origin can access the API (set to your explorer domain)
CURS3D_API_ALLOW_ORIGIN=https://explorer.example.com

# Optional: Bearer token for POST endpoints (generate with: openssl rand -hex 32)
CURS3D_API_TOKEN=

# Optional: Token for TCP RPC authentication
CURS3D_RPC_TOKEN=

# Faucet configuration
CURS3D_FAUCET_WALLET=/run/curs3d/faucet.json
CURS3D_FAUCET_PASSWORD_FILE=/run/curs3d/faucet.password
CURS3D_FAUCET_FEE=1000
